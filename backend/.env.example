PORT=5000

# MongoDB Atlas connection string (M0 free tier)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/pricesync

# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173

# Base URL of the frontend — used to build email verification links
FRONTEND_URL=http://localhost:5173

# Secret used to sign auth JWTs — generate with `openssl rand -hex 32`
JWT_SECRET=<random-hex-string>

# Optional SMTP config for price-drop alert emails. If unset, a free
# Ethereal test inbox is created automatically and preview URLs are logged.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=PriceSync <alerts@pricesync.app>
